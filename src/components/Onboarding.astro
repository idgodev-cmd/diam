---
// src/components/Onboarding.astro
---

<div id="pwa-onboarding" class="fixed inset-0 z-[100] hidden items-end sm:items-center justify-center p-4 sm:p-6 bg-black/40 backdrop-blur-sm transition-opacity duration-500 opacity-0">
    <div class="relative w-full max-w-md bg-white/80 dark:bg-dark-bg/80 backdrop-blur-md border border-white/20 dark:border-white/10 rounded-3xl shadow-2xl overflow-hidden transform transition-all duration-500 translate-y-20 sm:translate-y-0 sm:scale-95">
        
        <!-- Progress Dots -->
        <div class="absolute top-6 left-1/2 -translate-x-1/2 flex gap-2">
            <div class="w-8 h-1 rounded-full bg-accent transition-all duration-300" id="dot-1"></div>
            <div class="w-8 h-1 rounded-full bg-ink/10 dark:bg-white/10 transition-all duration-300" id="dot-2"></div>
            <div class="w-8 h-1 rounded-full bg-ink/10 dark:bg-white/10 transition-all duration-300" id="dot-3"></div>
        </div>

        <div class="p-8 pt-12 text-center">
            <!-- Slide 1: Welcome -->
            <div id="slide-1" class="slide active-slide">
                <div class="mb-6 inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-accent/10 text-accent transform rotate-6 animate-bounce-slow">
                    <i class="ph-bold ph-hands-clapping text-4xl"></i>
                </div>
                <h2 class="text-2xl font-black mb-3">Halo, Cuy!</h2>
                <p class="text-ink/60 dark:text-white/60 mb-8 leading-relaxed">
                    Selamat datang di <strong>diam.blog</strong>. Tempat gue nulis apa aja yang lewat di kepala, dari kegalauan sampe tips random.
                </p>
            </div>

            <!-- Slide 2: Native App Experience -->
            <div id="slide-2" class="slide hidden opacity-0 translate-x-10">
                <div class="mb-6 inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-amber-500/10 text-amber-500 transform -rotate-3">
                    <i class="ph-bold ph-lightning text-4xl"></i>
                </div>
                <h2 class="text-2xl font-black mb-3">Lebih Sat-set</h2>
                <p class="text-ink/60 dark:text-white/60 mb-8 leading-relaxed">
                    Sekarang diam.blog udah jadi "aplikasi" di HP lu. Aksesnya lebih cepet, gak perlu nunggu loading browser lagi.
                </p>
            </div>

            <!-- Slide 3: Offline Power -->
            <div id="slide-3" class="slide hidden opacity-0 translate-x-10">
                <div class="mb-6 inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-blue-500/10 text-blue-500 transform rotate-12">
                    <i class="ph-bold ph-wifi-high text-4xl"></i>
                </div>
                <h2 class="text-2xl font-black mb-3">Power of PWA</h2>
                <p class="text-ink/60 dark:text-white/60 mb-8 leading-relaxed">
                    Jangan lupa, semua artikel yang lu baca otomatis tersimpan. Jadi pas lagi di pesawat atau gak ada sinyal, tetep gas baca!
                </p>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col gap-3">
                <button id="next-btn" class="w-full py-4 bg-ink dark:bg-white text-white dark:text-ink font-bold rounded-2xl active:scale-95 transition-transform shadow-lg shadow-ink/20 dark:shadow-white/10">
                    Lanjut
                </button>
                <button id="skip-btn" class="text-sm font-bold text-ink/40 dark:text-white/40 hover:text-accent transition-colors py-2">
                    Skip Intro
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .animate-bounce-slow {
        animation: bounce 3s infinite;
    }
    @keyframes bounce {
        0%, 100% { transform: translateY(0) rotate(6deg); }
        50% { transform: translateY(-10px) rotate(6deg); }
    }
    .slide {
        transition: all 0.5s ease;
    }
    .slide.active-slide {
        display: block !important;
        opacity: 1 !important;
        transform: translateX(0) !important;
    }
</style>

<script>
    document.addEventListener('astro:page-load', () => {
        const onboarding = document.getElementById('pwa-onboarding');
        const nextBtn = document.getElementById('next-btn');
        const skipBtn = document.getElementById('skip-btn');
        const slides = [
            document.getElementById('slide-1'),
            document.getElementById('slide-2'),
            document.getElementById('slide-3')
        ];
        const dots = [
            document.getElementById('dot-1'),
            document.getElementById('dot-2'),
            document.getElementById('dot-3')
        ];

        let currentSlide = 0;

        // DETEKSI STANDALONE (APPterpasang)
        const isStandalone = window.matchMedia('(display-mode: standalone)').matches || (window.navigator as any).standalone === true;

        // Cek kalau udah pernah liat onboarding app atau BUKAN di standalone mode
        if (localStorage.getItem('pwa-app-onboarding-done') || !isStandalone) {
            return;
        }

        // Show onboarding with delay (hanya di App)
        setTimeout(() => {
            if (onboarding) {
                onboarding.classList.replace('hidden', 'flex');
                setTimeout(() => {
                    onboarding.classList.replace('opacity-0', 'opacity-100');
                    const content = onboarding.firstElementChild as HTMLElement;
                    if (content) content.classList.remove('translate-y-20', 'sm:scale-95');
                }, 10);
            }
        }, 1500);

        const showSlide = (index: number) => {
            slides.forEach((s, i) => {
                if (i === index) {
                    s?.classList.remove('hidden');
                    setTimeout(() => s?.classList.add('active-slide'), 10);
                } else {
                    s?.classList.remove('active-slide');
                    setTimeout(() => s?.classList.add('hidden'), 500);
                }
            });

            dots.forEach((d, i) => {
                const target = d as HTMLElement;
                if (!target) return;
                
                if (i === index) {
                    target.className = "w-8 h-1 rounded-full bg-accent transition-all duration-300";
                } else {
                    target.className = "w-8 h-1 rounded-full bg-ink/10 dark:bg-white/10 transition-all duration-300";
                }
            });

            if (index === 2 && nextBtn) {
                nextBtn.innerText = 'Gas, Mulai Baca!';
            }
        };

        function closeOnboarding() {
            if (onboarding) {
                onboarding.classList.replace('opacity-100', 'opacity-0');
                const content = onboarding.firstElementChild as HTMLElement;
                if (content) content.classList.add('translate-y-20', 'sm:scale-95');
                setTimeout(() => {
                    onboarding.classList.replace('flex', 'hidden');
                    localStorage.setItem('pwa-app-onboarding-done', 'true');
                }, 500);
            }
        }

        nextBtn?.addEventListener('click', () => {
            if (currentSlide < 2) {
                currentSlide++;
                showSlide(currentSlide);
            } else {
                closeOnboarding();
            }
        });

        skipBtn?.addEventListener('click', closeOnboarding);
    });
</script>
