---
interface Props {
    currentSlug: string;
    allPosts: any[];
}

const { currentSlug, allPosts } = Astro.props;

// Sort by date
const sorted = [...allPosts].sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
const currentIndex = sorted.findIndex(p => p.slug === currentSlug);

const nextPost = currentIndex >= 0 && currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const prevPost = currentIndex > 0 ? sorted[currentIndex - 1] : null;
---

{(prevPost || nextPost) && (
    <nav class="mt-16 pt-8 border-t border-gray-100 dark:border-gray-800">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {prevPost && (
                <a href={`/blog/${prevPost.slug}`} class="group flex flex-col gap-2 p-5 rounded-2xl border border-gray-100 dark:border-gray-800 hover:border-accent/50 hover:shadow-lg hover:shadow-accent/5 transition-all">
                    <span class="text-xs text-gray-400 font-medium uppercase tracking-wider flex items-center gap-1">
                        <i class="ph-bold ph-arrow-left"></i> Sebelumnya
                    </span>
                    <h4 class="font-display font-bold text-lg group-hover:text-accent transition-colors line-clamp-2">
                        {prevPost.data.title}
                    </h4>
                </a>
            )}
            {nextPost && (
                <a href={`/blog/${nextPost.slug}`} class={`group flex flex-col gap-2 p-5 rounded-2xl border border-gray-100 dark:border-gray-800 hover:border-accent/50 hover:shadow-lg hover:shadow-accent/5 transition-all text-right ${!prevPost ? 'md:col-start-2' : ''}`}>
                    <span class="text-xs text-gray-400 font-medium uppercase tracking-wider flex items-center gap-1 justify-end">
                        Selanjutnya <i class="ph-bold ph-arrow-right"></i>
                    </span>
                    <h4 class="font-display font-bold text-lg group-hover:text-accent transition-colors line-clamp-2">
                        {nextPost.data.title}
                    </h4>
                </a>
            )}
        </div>
    </nav>
)}
